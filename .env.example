# --- Database ---
POSTGRES_USER=askfluence
POSTGRES_PASSWORD=askfluence
POSTGRES_DB=askfluence
DATABASE_URL=postgresql://askfluence:changeme@localhost:5432/askfluence

# --- API security ---
# Set to false for local UI-only mode (no bearer token required).
AUTH_REQUIRED=true
# Comma-separated bearer tokens accepted by the /ask endpoint.
API_KEYS=replace-with-a-long-random-string
# Comma-separated allowed CORS origins (use exact origins, no wildcard in prod).
CORS_ORIGINS=http://localhost:3000

# --- GitHub Models (LLM + embeddings) ---
# Create a fine-grained PAT with "Models" read access at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_me
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# --- Confluence ---
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@your-org.com
CONFLUENCE_API_TOKEN=replace_me
CONFLUENCE_SPACES=ENG,PRODUCT

# --- Retrieval ---
TOP_K=5
MAX_QUESTION_CHARS=2000
